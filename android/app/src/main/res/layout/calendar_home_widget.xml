<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/calendar_widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:padding="0dp">

    <ImageView
        android:id="@+id/calendar_widget_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitStart"
        android:adjustViewBounds="false"
        android:contentDescription="@string/calendar_widget_content_description"
        android:visibility="gone" />

    <TextView
        android:id="@+id/calendar_widget_placeholder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="@string/calendar_widget_placeholder"
        android:textSize="16sp" />
</FrameLayout>
